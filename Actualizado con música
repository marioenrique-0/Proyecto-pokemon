import json
import streamlit as st
from pathlib import Path

def menus():
    # 1. INICIALIZAR ESTADOS (Música apagada al iniciar la aplicación)
    if "reproducir_musica" not in st.session_state:
        st.session_state.reproducir_musica = False  
    if "pantalla_actual" not in st.session_state:
        st.session_state.pantalla_actual = "menu"
    if "nivel_volumen" not in st.session_state:
        st.session_state.nivel_volumen = "Normal"

    # --- 2. CONTENEDOR DE AUDIO PERSISTENTE (Fijo en la cabecera de la app) ---
    # Reservamos un espacio inmutable en la memoria para alojar el audio
    reproductor_global = st.empty()

    # Si la música está activa por estado y no está silenciada, se inyecta en el espacio reservado
    if st.session_state.reproducir_musica and st.session_state.nivel_volumen == "Normal":
        try:
            # Al vivir dentro de 'reproductor_global', Streamlit no reinicia la pista al abrir el popover
            reproductor_global.audio("eleccion.mp3", format="audio/mp3", loop=True, autoplay=True)
        except FileNotFoundError:
            reproductor_global.empty()
    else:
        # Si el usuario silencia o apaga, vaciamos el reproductor limpiamente
        reproductor_global.empty()

    # --- PANTALLA: MENÚ INICIAL ---
    if st.session_state.pantalla_actual == "menu":
        st.subheader("MENU INICIAL")
        try:
            st.video("Intro.mp4", autoplay=True)
        except FileNotFoundError:
            st.warning("Video no encontrado.")

        col1, col2, col3 = st.columns(3)
        with col2:
            # AL PRESIONAR ESTE BOTÓN LA MÚSICA SE ENCIENDE AL INSTANTE
            if st.button("INICIAR JUEGO", use_container_width=True):
                st.session_state.modo_juego = "1vs1"
                st.session_state.pantalla_actual = "juego"
                st.session_state.reproducir_musica = True  # <- Detonante inmediato de la música
                st.rerun()

    # --- PANTALLA: SELECCIÓN DE JUEGO ---
    elif st.session_state.pantalla_actual == "juego":
        col_titulo, col_config = st.columns([0.85, 0.15])
        
        with col_titulo:
            st.subheader(f"Modo de juego: {st.session_state.get('modo_juego', 'Normal')}")
            
        with col_config:
            # 3. CONTROL DE CONFIGURACIÓN ESTABLE
            with st.popover("⚙"):
                st.subheader("Configuración")
                
                # Modificamos los estados de memoria directamente sin forzar st.rerun manuales destructivos
                musica_activa = st.toggle("Música de fondo", value=st.session_state.reproducir_musica)
                if musica_activa != st.session_state.reproducir_musica:
                    st.session_state.reproducir_musica = musica_activa
                    st.rerun()
                

        # Botón para regresar al menú principal de la aplicación
        if st.button("Volver al Menú Principal"):
            st.session_state.pantalla_actual = "menu"
            st.session_state.reproducir_musica = False  # Apagamos la música de fondo al regresar
            st.rerun()
            
        # Ejecución normal de la selección de personajes
        selecion()

    # --- PANTALLA: COMBATE ---
    elif st.session_state.pantalla_actual == "combate":
        combate()
menus()
